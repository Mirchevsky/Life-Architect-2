<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="oval">
            <size
                android:width="20dp"
                android:height="20dp" />
            <solid android:color="@color/widget_checkbox_glow_halo_pinned" />
        </shape>
    </item>

    <item
        android:top="2dp"
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="4dp" />
            <solid android:color="@color/widget_checkbox_fill_pinned" />
            <stroke
                android:width="1.5dp"
                android:color="@color/widget_pinned" />
        </shape>
    </item>

</layer-list>