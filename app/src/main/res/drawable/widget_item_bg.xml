<?xml version="1.0" encoding="utf-8"?>
<!--
    widget_item_bg.xml
    ─────────────────────────────────────────────────────────────────────────
    Card background for each task row in the widget.

    Uses @color/widget_item_card which is defined in both:
      res/values/colors_widget.xml       (light: #E8E8F0)
      res/values-night/colors_widget.xml (dark:  #2A2740)

    Android automatically picks the correct variant based on the system's
    night-mode setting, so the card looks correct in both light and dark mode.

    Place at: app/src/main/res/drawable/widget_item_bg.xml
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/widget_item_card" />
    <corners android:radius="10dp" />
</shape>
