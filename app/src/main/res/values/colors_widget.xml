<?xml version="1.0" encoding="utf-8"?>
<!--
    colors_widget.xml  (default = light mode)
    ─────────────────────────────────────────────────────────────────────────
    Widget colour tokens for LIGHT mode.
    Dark-mode counterparts live in res/values-night/colors_widget.xml.

    Place at: app/src/main/res/values/colors_widget.xml
-->
<resources>
    <!-- Widget outer frame background -->
    <color name="widget_background">#FFFFFF</color>

    <!-- Task row card background — white cards on gray background -->
    <color name="widget_item_card">#F3F4F6</color>

    <!-- Divider line between rows -->
    <color name="widget_divider">#E5E7EB</color>

    <!-- Primary text (task titles) -->
    <color name="widget_text_primary">#111827</color>

    <!-- Secondary text (due dates, empty state) -->
    <color name="widget_text_secondary">#6B7280</color>

    <!-- Inactive icon tint (flag, pin, checkbox when not active) -->
    <color name="widget_icon_inactive">#9CA3AF</color>

    <!-- Checkbox unchecked border -->
    <color name="widget_checkbox_stroke">#9CA3AF</color>

    <!-- Urgent task text and flag icon -->
    <color name="widget_urgent">#EF4444</color>

    <!-- Pinned task text and pin icon -->
    <color name="widget_pinned">#F59E0B</color>

    <!-- Accent green (Add button background) -->
    <color name="widget_accent_green">#10B981</color>

    <!-- Accent purple (Calendar button background) -->
    <color name="widget_accent_purple">#7C3AED</color>

    <!-- Button icon / text colour -->
    <color name="widget_btn_icon">#FFFFFF</color>
</resources>
