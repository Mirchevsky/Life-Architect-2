<?xml version="1.0" encoding="utf-8"?> <!-- widget_task_item_pinned.xml Task row layout for PINNED tasks. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:id="@+id/widget_item_root" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="8dp" android:paddingEnd="2dp" android:background="@drawable/widget_item_bg" android:minHeight="52dp">

    <ImageView
        android:id="@+id/widget_item_dot"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginEnd="8dp"
        android:src="@drawable/widget_checkbox_glow"
        android:contentDescription="Task status"
        android:visibility="visible" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_item_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/widget_text_primary"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <LinearLayout
            android:id="@+id/widget_item_date_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_item_due"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp"
                android:maxLines="1" />

            <ImageView
                android:id="@+id/widget_item_calendar"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="3dp"
                android:src="@drawable/widget_ic_calendar"
                android:contentDescription="Calendar event"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:text=""
            android:visibility="invisible" />

        <FrameLayout
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="5dp">

            <ImageView
                android:id="@+id/widget_item_flag"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_task_flag_non_urgent"
                android:contentDescription="Toggle urgent"
                android:visibility="visible" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="5dp">

            <ImageView
                android:id="@+id/widget_item_pin"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/widget_ic_pin"
                android:contentDescription="Toggle pin"
                android:visibility="visible" />
        </FrameLayout>
    </LinearLayout>
</LinearLayout>