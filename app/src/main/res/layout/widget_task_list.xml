<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/widget_header_identity_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_header_avatar"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="U"
                android:textColor="@color/widget_text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/widget_avatar_circle" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_header_level_xp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Level 1"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:maxLines="1" />

                <ProgressBar
                    android:id="@+id/widget_header_xp_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="12dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/widget_accent_green"
                    android:progressBackgroundTint="@color/widget_divider" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/widget_btn_mic"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@android:color/transparent"
                android:src="@drawable/widget_ic_mic"
                android:tint="@color/widget_btn_icon"
                android:contentDescription="Voice input"
                android:scaleType="centerInside"
                android:padding="7dp" />

            <ImageButton
                android:id="@+id/widget_btn_add_event"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="5dp"
                android:background="@android:color/transparent"
                android:src="@drawable/widget_ic_calendar"
                android:tint="@color/widget_btn_icon"
                android:contentDescription="Add calendar event"
                android:scaleType="centerInside"
                android:padding="7dp" />

            <ImageButton
                android:id="@+id/widget_btn_add_task"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="5dp"
                android:background="@android:color/transparent"
                android:src="@drawable/widget_ic_add"
                android:tint="@color/widget_btn_icon"
                android:contentDescription="Add task"
                android:scaleType="centerInside"
                android:padding="7dp" />

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/widget_divider"
        android:layout_marginBottom="4dp"
        android:text="" />

    <ListView
        android:id="@+id/widget_task_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@color/widget_divider"
        android:dividerHeight="1dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        android:overScrollMode="never" />

    <TextView
        android:id="@+id/widget_empty_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No pending tasks"
        android:textColor="@color/widget_text_secondary"
        android:textSize="13sp"
        android:visibility="gone" />
</LinearLayout>