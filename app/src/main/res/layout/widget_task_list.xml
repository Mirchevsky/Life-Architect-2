<?xml version="1.0" encoding="utf-8"?>
<!--
    widget_task_list.xml
    ─────────────────────────────────────────────────────────────────────────
    Main frame layout for the Life Architect 2 task list home screen widget.

    Structure:
    ┌─────────────────────────────────────────────┐
    │ Tasks                          [mic] [cal] [+] │ ← header row
    │─────────────────────────────────────────────│ ← divider
    │ • Task title                     Mar 29, 22:00 │
    │ • Task title                                  │ ← ListView rows
    │ • Task title                     Mar 24, 09:00 │
    │ …                                               │
    └─────────────────────────────────────────────┘

    Button order matches AddTaskItem.kt:
    Mic → Calendar → Add (left to right).

    Colours use @color/widget_* references that resolve to light or dark
    variants automatically based on the system night-mode setting:
      res/values/colors_widget.xml        (light mode defaults)
      res/values-night/colors_widget.xml  (dark mode overrides)

    Place at:
    app/src/main/res/layout/widget_task_list.xml
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background">

    <!-- ── Header row ──────────────────────────────────────────────────── -->
    <!--
        Two-column header:
          Left  : "Tasks" title, vertically centred
          Right : vertical stack — empty spacer on top (aligns with title),
                  then the three action buttons on the bottom row so that
                  [calendar] sits on the same horizontal centre-line as the
                  flag icon in each task row, and [+] on the same line as pin.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp">

        <!-- Widget title -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tasks"
            android:textColor="@color/widget_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!--
            Button group — pushed to the bottom of the header so the buttons
            sit flush with the top task row's icon band.
        -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Mic button -->
            <ImageButton
                android:id="@+id/widget_btn_mic"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@android:color/transparent"
                android:src="@drawable/widget_ic_mic"
                android:tint="@color/widget_btn_icon"
                android:contentDescription="Voice input"
                android:scaleType="centerInside"
                android:padding="7dp" />

            <!-- Calendar button — centre-aligns with flag icon in task rows -->
            <ImageButton
                android:id="@+id/widget_btn_add_event"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="5dp"
                android:background="@android:color/transparent"
                android:src="@drawable/widget_ic_calendar"
                android:tint="@color/widget_btn_icon"
                android:contentDescription="Add calendar event"
                android:scaleType="centerInside"
                android:padding="7dp" />

            <!-- Add Task button — centre-aligns with pin icon in task rows -->
            <ImageButton
                android:id="@+id/widget_btn_add_task"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="5dp"
                android:background="@android:color/transparent"
                android:src="@drawable/widget_ic_add"
                android:tint="@color/widget_btn_icon"
                android:contentDescription="Add task"
                android:scaleType="centerInside"
                android:padding="7dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── Divider ─────────────────────────────────────────────────────── -->
    <!-- Note: plain android.view.View is not on the RemoteViews allowlist in
         API 31+. Use TextView with empty text as a safe divider instead. -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/widget_divider"
        android:layout_marginBottom="4dp"
        android:text="" />

    <!-- ── Task list (populated by TaskWidgetService / RemoteViewsFactory) -->
    <ListView
        android:id="@+id/widget_task_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@color/widget_divider"
        android:dividerHeight="1dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        android:overScrollMode="never" />

    <!-- ── Empty state (shown automatically when ListView has no items) ── -->
    <TextView
        android:id="@+id/widget_empty_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No pending tasks"
        android:textColor="@color/widget_text_secondary"
        android:textSize="13sp"
        android:visibility="gone" />
</LinearLayout>