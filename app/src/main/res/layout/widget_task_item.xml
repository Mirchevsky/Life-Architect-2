<?xml version="1.0" encoding="utf-8"?>
<!-- widget_task_item.xml
     Single task row for the Life Architect 2 home screen widget.

     Layout (matches in-app TaskItem style):
     ┌─────────────────────────────────────────────────────────────┐
     │ [ ] Task title 🚩 📌                                       │
     │ Mar 29, 22:00 📅                                           │
     └─────────────────────────────────────────────────────────────┘

     Notes:
     - All children are RemoteViews-safe.
     - Root and spacing align with header action icons in widget_task_list.xml.

     Place at: app/src/main/res/layout/widget_task_item.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_item_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="8dp"
    android:paddingEnd="2dp"
    android:background="@drawable/widget_item_bg"
    android:minHeight="52dp">

    <!-- Checkbox / completion indicator -->
    <ImageView
        android:id="@+id/widget_item_dot"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginEnd="8dp"
        android:src="@drawable/widget_checkbox_glow"
        android:contentDescription="Task status"
        android:visibility="visible" />

    <!-- Text column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_item_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/widget_accent_green"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Date row -->
        <LinearLayout
            android:id="@+id/widget_item_date_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_item_due"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp"
                android:maxLines="1" />

            <!-- Calendar icon — shown only for event rows -->
            <ImageView
                android:id="@+id/widget_item_calendar"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="3dp"
                android:src="@drawable/widget_ic_calendar"
                android:contentDescription="Calendar event"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- Flag icon — always visible -->
    <ImageView
        android:id="@+id/widget_item_flag"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginStart="-5dp"
        android:src="@drawable/widget_ic_flag"
        android:contentDescription="Toggle urgent"
        android:visibility="visible" />

    <!-- Pin icon — always visible -->
    <ImageView
        android:id="@+id/widget_item_pin"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:src="@drawable/widget_ic_pin"
        android:contentDescription="Toggle pin"
        android:visibility="visible" />
</LinearLayout>