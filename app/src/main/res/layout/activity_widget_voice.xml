<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/widget_background">

    <!-- Dialog title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/voice_input"
        android:textColor="@color/widget_text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Status label — updated dynamically by WidgetVoiceActivity -->
    <TextView
        android:id="@+id/widget_voice_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/listening"
        android:textColor="@color/widget_text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="12dp" />

    <!-- Recognised text input — pre-filled after recognition, editable -->
    <EditText
        android:id="@+id/widget_voice_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Recognised text will appear here"
        android:textColor="@color/widget_text_primary"
        android:textColorHint="@color/widget_text_secondary"
        android:background="@drawable/widget_input_background"
        android:padding="10dp"
        android:inputType="textCapSentences"
        android:imeOptions="actionDone"
        android:layout_marginBottom="12dp" />

    <!-- Mic button — centred, tappable to re-record -->
    <ImageButton
        android:id="@+id/widget_voice_mic_btn"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center_horizontal"
        android:background="@android:color/transparent"
        android:src="@drawable/widget_ic_mic"
        android:contentDescription="@string/start_voice_input"
        android:scaleType="centerInside"
        android:padding="8dp"
        android:layout_marginBottom="16dp" />

    <!-- Cancel / Save button row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/widget_voice_cancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/cancel"
            android:textColor="#7C3AED"
            android:background="@android:color/transparent"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/widget_voice_save"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/save"
            android:textColor="#FFFFFF"
            android:backgroundTint="#7C3AED" />

    </LinearLayout>
</LinearLayout>