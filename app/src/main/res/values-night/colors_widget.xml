<resources>
    <!-- Widget outer frame background -->
    <color name="widget_background">#0B0F14</color>

    <!-- Task row card background -->
    <color name="widget_item_card">#141A22</color>

    <!-- Divider line between rows -->
    <color name="widget_divider">#1F2933</color>

    <!-- Primary text (task titles) -->
    <color name="widget_text_primary">#F3F4F6</color>

    <!-- Secondary text (due dates, empty state) -->
    <color name="widget_text_secondary">#9CA3AF</color>

    <!-- Inactive icon tint (flag, pin, checkbox when not active) -->
    <color name="widget_icon_inactive">@color/white</color>

    <!-- Checkbox unchecked border -->
    <color name="widget_checkbox_stroke">@color/white</color>

    <!-- Urgent task text and flag icon -->
    <color name="widget_urgent">#F87171</color>

    <!-- Pinned task text and pin icon -->
    <color name="widget_pinned">#FBBF24</color>

    <!-- Accent green (Add button background) -->
    <color name="widget_accent_green">#10B981</color>
    <color name="widget_checkbox_fill">#4710B981</color>
    <color name="widget_checkbox_glow_halo">#5210B981</color>
    <color name="widget_checkbox_fill_pinned">#47FBBF24</color>
    <color name="widget_checkbox_glow_halo_pinned">#52FBBF24</color>
    <color name="widget_checkbox_fill_urgent">#47F87171</color>
    <color name="widget_checkbox_glow_halo_urgent">#52F87171</color>

    <!-- Accent purple (Calendar button background) -->
    <color name="widget_accent_purple">#7C3AED</color>

    <!-- Button icon / text colour -->
    <color name="widget_btn_icon">#FFFFFF</color>
</resources>